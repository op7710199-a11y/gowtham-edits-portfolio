import { useState } from 'react';
import { supabase } from '../../lib/supabase';
import { recommendPackage } from '../../utils/serviceRecommender';
import { Calculator, CheckCircle2 } from 'lucide-react';

export function ServiceRecommender() {
  const [result, setResult] = useState<any>(null);
  const [form, setForm] = useState({ name: '', email: '', service: 'Wedding Video Editing', budget: 5000, duration: 5, delivery: 'Standard' });

  const handleRecommend = async () => {
    const rec = recommendPackage(form);
    
    await supabase.from("ai_requests").insert([{
      tool_type: "service_recommender",
      name: form.name,
      email: form.email,
      service: form.service,
      recommended_service: rec.package,
      status: "new"
    }]);

    setResult(rec);
  };

  return (
    <div className="p-8 rounded-3xl border border-gold-500/20 bg-black/40 backdrop-blur-xl">
      <h2 className="text-2xl font-bold text-white mb-6">Service Recommender</h2>
      {!result ? (
        <div className="grid gap-4">
           {/* Inputs for name, email, select service, duration, delivery type */}
           <button onClick={handleRecommend} className="btn-primary w-full py-4">Get Recommendation</button>
        </div>
      ) : (
        <div className="space-y-6 text-white">
          <div className="text-center p-6 bg-gold-500/10 rounded-2xl">
            <div className="text-sm uppercase tracking-widest text-gold-400">Recommended Package</div>
            <div className="text-3xl font-bold">{result.package}</div>
          </div>
          
          <ul className="space-y-2">
            {result.reasons.map((r: string, i: number) => (
              <li key={i} className="flex items-center gap-2 text-sm text-stone-300">
                <CheckCircle2 size={16} className="text-green-500" /> {r}
              </li>
            ))}
          </ul>
          
          <div className="grid grid-cols-2 gap-3">
             <button className="btn-ghost text-xs">Copy</button>
             <button className="btn-primary text-xs">Contact Now</button>
          </div>
        </div>
      )}
    </div>
  );
}
